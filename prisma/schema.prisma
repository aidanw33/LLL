generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Video {
  id        String               @id @default(uuid())
  youtubeId String               @unique
  title     String
  language  String?
  createdAt DateTime             @default(now())
  segments        TranscriptSegment[]
  users           UserVideo[]
  translationLogs TranslationLog[]

  @@map("videos")
}

model UserVideo {
  id        String   @id @default(uuid())
  userId    String
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, videoId])
  @@index([userId])
  @@map("user_videos")
}

model TranslationLog {
  id              String   @id @default(uuid())
  videoId         String
  video           Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  usedGoogleApi   Boolean
  characterCount  Int
  createdAt       DateTime @default(now())

  @@map("translation_logs")
}

model TranscriptSegment {
  id             String @id @default(uuid())
  videoId        String
  video          Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  startTime      Float
  duration       Float
  originalText   String
  translatedText String
  segmentIndex   Int

  @@index([videoId, segmentIndex])
  @@map("transcript_segments")
}
